# Netlify server-side TMDB key (recommended for production)
# Set this in Netlify site environment variables, not in client env files.
TMDB_API_KEY=YOUR_TMDB_API_KEY

# Client fallback key (optional, for local development only)
# Do not set this in production if using Netlify proxy.
VITE_TMDB_API_KEY=

# Use Netlify proxy by default in production/local
VITE_USE_TMDB_PROXY=true
